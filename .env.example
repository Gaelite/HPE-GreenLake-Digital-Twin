# =============================================================
# Digital Twin - Emergency Vehicles POC
# Environment Variables
# =============================================================
# Copy this file to .env.local and fill in your Supabase values:
#   cp .env.example .env.local
# =============================================================

# Supabase — Project URL (found in Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase — Anon/Public Key (found in Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — Service Role Key (found in Settings > API)
# WARNING: This key bypasses Row Level Security. Never expose it client-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# TomTom Routing API Key (https://developer.tomtom.com/)
# If set, routes use TomTom with dynamic "avoid areas" for obstacle avoidance.
# If not set, falls back to OSRM (no avoid-area support).
TOMTOM_API_KEY=your-tomtom-api-key
